generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  school        String?
  schools       String[] @default([])
  identity      String?
  department    String?
  researchField String?
  role          UserRole @default(STUDENT)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  topics        Topic[]
  replies       Reply[]
  aiSessions    AIChatSession[]
  aiDrafts      AIDraft[]
  topicViews     TopicView[]
  recommendationBatch RecommendationBatch?
  topicPreference UserTopicPreference?
  createdDisciplines Discipline[] @relation("DisciplineCreator")
  createdTags        Tag[]        @relation("TagCreator")
}

model UserTopicPreference {
  userId        String   @id
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tagIds        String[] @default([])
  disciplineIds String[] @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Discipline {
  id           String         @id @default(cuid())
  name         String
  slug         String         @unique
  parentId     String?
  parent       Discipline?    @relation("DisciplineTree", fields: [parentId], references: [id])
  children     Discipline[]   @relation("DisciplineTree")
  sortOrder    Int            @default(0)
  reviewStatus ApprovalStatus @default(APPROVED)
  createdById  String?
  createdBy    User?          @relation("DisciplineCreator", fields: [createdById], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tags         Tag[]
  tagLinks     TagDiscipline[]
  topics       Topic[]
  topicLinks   TopicDiscipline[]
}

model Tag {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  disciplineId  String?
  discipline    Discipline?    @relation(fields: [disciplineId], references: [id])
  reviewStatus  ApprovalStatus @default(APPROVED)
  reviewReason  String?
  createdById   String?
  createdBy     User?          @relation("TagCreator", fields: [createdById], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  topics        TopicTag[]
  disciplines   TagDiscipline[]
}

model TagDiscipline {
  tagId        String
  disciplineId String

  tag          Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)
  discipline   Discipline @relation(fields: [disciplineId], references: [id], onDelete: Cascade)

  @@id([tagId, disciplineId])
}

model Topic {
  id                  String       @id @default(cuid())
  title               String
  type                TopicType
  body                String
  paperTitle          String?
  paperUrl            String?
  authorId            String
  author              User         @relation(fields: [authorId], references: [id])
  primaryDisciplineId String
  primaryDiscipline   Discipline   @relation(fields: [primaryDisciplineId], references: [id])
  status              TopicStatus  @default(PUBLISHED)
  viewCount           Int          @default(0)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  lastActivityAt      DateTime     @default(now())

  tags                TopicTag[]
  replies             Reply[]
  aiGuide             AIGuide?
  aiSessions          AIChatSession[]
  aiDrafts            AIDraft[]
  disciplines         TopicDiscipline[]
  topicViews          TopicView[]
  recommendationItems RecommendationItem[]
}

model TopicTag {
  topicId String
  tagId   String

  topic   Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  tag     Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([topicId, tagId])
}

model TopicDiscipline {
  topicId      String
  disciplineId String

  topic        Topic      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  discipline   Discipline @relation(fields: [disciplineId], references: [id], onDelete: Cascade)

  @@id([topicId, disciplineId])
}

model Reply {
  id            String   @id @default(cuid())
  topicId       String
  topic         Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  authorId      String
  author        User     @relation(fields: [authorId], references: [id])
  body          String
  parentReplyId String?
  parentReply   Reply?   @relation("ReplyThread", fields: [parentReplyId], references: [id])
  childReplies  Reply[]  @relation("ReplyThread")
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AIGuide {
  id             String        @id @default(cuid())
  topicId        String        @unique
  topic          Topic         @relation(fields: [topicId], references: [id], onDelete: Cascade)
  content        String
  oneLineSummary String?
  model          String
  status         AIJobStatus   @default(COMPLETED)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model TopicView {
  id            String   @id @default(cuid())
  userId        String
  topicId       String
  firstViewedAt DateTime @default(now())
  lastViewedAt  DateTime @default(now())
  viewCount     Int      @default(1)

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic         Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@index([topicId])
}

model RecommendationBatch {
  id               String               @id @default(cuid())
  userId           String               @unique
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateKey          String
  algorithmVersion String
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  items            RecommendationItem[]
}

model RecommendationItem {
  id        String                 @id @default(cuid())
  batchId   String
  topicId   String
  slotType  RecommendationSlotType
  position  Int
  score     Float
  createdAt DateTime               @default(now())

  batch     RecommendationBatch     @relation(fields: [batchId], references: [id], onDelete: Cascade)
  topic     Topic                   @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([batchId, position])
  @@index([topicId])
}

model AIChatSession {
  id        String          @id @default(cuid())
  topicId   String
  topic     Topic           @relation(fields: [topicId], references: [id], onDelete: Cascade)
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  createdAt DateTime        @default(now())

  messages  AIChatMessage[]
}

model AIChatMessage {
  id        String        @id @default(cuid())
  sessionId String
  session   AIChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      AIMessageRole
  content   String
  createdAt DateTime      @default(now())
}

model AIDraft {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  topicId   String
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  input     String
  output    String
  createdAt DateTime @default(now())
}

enum UserRole {
  STUDENT
  MODERATOR
  ADMIN
}

enum TopicType {
  PAPER
  QUESTION
  IDEA
  RECOMMENDATION
}

enum TopicStatus {
  DRAFT
  PUBLISHED
  HIDDEN
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AIJobStatus {
  PENDING
  COMPLETED
  FAILED
}

enum AIMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum RecommendationSlotType {
  FAMILIAR
  ADJACENT
  CROSS_FIELD
}
